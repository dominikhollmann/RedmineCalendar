{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "if": "Write(*.js)|Edit(*.js)|Write(*.html)|Edit(*.html)",
            "command": "cd /home/dominik/RedmineCalendar && npm test 2>&1 | tail -5",
            "timeout": 30,
            "statusMessage": "Running unit tests..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "sleep 15 && cd /home/dominik/RedmineCalendar && ~/bin/gh run list --limit 1 --json status,conclusion,name --jq '.[0]' 2>/dev/null || true",
            "timeout": 60,
            "async": true,
            "asyncRewake": true,
            "rewakeMessage": "CI status after push:",
            "statusMessage": "Checking CI status..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npx playwright test)",
      "Bash(npx playwright test *)",
      "Bash(npx vitest run *)",
      "Bash(pytest *)",
      "Bash(git add *)",
      "Bash(git commit)",
      "Bash(git commit -m *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git pull)",
      "Bash(git pull --rebase)",
      "Bash(git pull --rebase *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Read(**/*.js)",
      "Read(**/*.md)",
      "Edit(**/*.js)",
      "Edit(**/*.md)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(curl *|*)",
      "Bash(wget *|*)",
      "Bash(env)", "Bash(printenv)", "Bash(set)",
      "Bash(cat ~/.aws/*)", "Bash(cat ~/.ssh/*)",
      "Bash(ssh *)", "Bash(scp *)",
      "Bash(kubectl apply *)", "Bash(kubectl delete *)",
      "Bash(terraform apply *)", "Bash(terraform destroy *)",
      "Bash(cdk deploy *)", "Bash(cdk destroy *)",
      "Bash(npm install *)", "Bash(pip install *)",
      "Bash(brew install *)", "Bash(apt install *)",
      "Bash(git push --force*)", "Bash(git push -f*)",
      "Bash(git push * --force*)", "Bash(git push * -f *)",
      "Bash(git push --no-verify*)", "Bash(git push * --no-verify*)",
      "Bash(git commit --no-verify*)", "Bash(git commit * --no-verify*)",
      "Bash(git commit --amend*)",
      "Bash(git reset --hard*)", "Bash(git reset * --hard*)",
      "Bash(git clean -f*)", "Bash(git clean -df*)", "Bash(git clean -fd*)",
      "Bash(git branch -D *)", "Bash(git branch --delete*)",
      "Bash(git checkout -- *)", "Bash(git checkout .)",
      "Bash(git restore .)", "Bash(git restore --source*)",
      "Read(.env)", "Read(.env.*)",
      "Read(secrets/**)", "Read(~/.aws/**)", "Read(~/.ssh/**)",
      "WebSearch", "WebFetch"
    ]
  }
}

