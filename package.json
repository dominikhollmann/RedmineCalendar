{
  "name": "redmine-calendar",
  "version": "1.0.0",
  "description": "Outlook-style weekly calendar for Redmine time tracking",
  "type": "module",
  "scripts": {
    "serve": "npx serve . -p 3000",
    "serve:https": "npx serve . -p 3000 --ssl-cert .certs/cert.pem --ssl-key .certs/key.pem",
    "dev": "node scripts/dev-server.mjs",
    "test": "vitest run --config tests/vitest.config.js",
    "test:watch": "vitest --config tests/vitest.config.js",
    "test:coverage": "vitest run --config tests/vitest.config.js --coverage",
    "test:ui": "playwright test --config tests/playwright.config.js",
    "test:ui:coverage": "PW_COVERAGE=1 playwright test --config tests/playwright.config.js",
    "test:coverage:merged": "node scripts/coverage-merge.mjs",
    "test:coverage:all": "npm run test:coverage && (npm run test:ui:coverage; npm run test:coverage:merged)",
    "test:all": "vitest run --config tests/vitest.config.js && playwright test --config tests/playwright.config.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "htmlhint": "htmlhint *.html",
    "sqi": "node scripts/sqi.mjs",
    "sqi:json": "node scripts/sqi.mjs --json",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.html": [
      "htmlhint"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@playwright/test": "^1.52.0",
    "@vitest/coverage-v8": "^3.2.1",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.13.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "madge": "^8.0.0",
    "monocart-coverage-reports": "^2.10.0",
    "prettier": "^3.4.2",
    "serve": "^14.0.0",
    "vitest": "^3.2.1"
  }
}
