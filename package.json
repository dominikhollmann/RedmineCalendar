{
  "name": "redmine-calendar",
  "version": "1.0.0",
  "description": "Outlook-style weekly calendar for Redmine time tracking",
  "scripts": {
    "serve": "npx serve . -p 3000",
    "serve:staging": "npx serve ../RedmineCalendar-staging -p 3001",
    "worktree:switch-staging": "node -e \"const{execSync}=require('child_process');const b=process.argv[1];execSync('git -C ../RedmineCalendar-staging checkout '+b,{stdio:'inherit'});console.log('Staging → '+b);\""
  },
  "devDependencies": {
    "local-cors-proxy": "^1.1.0",
    "serve": "^14.0.0"
  }
}
