{
  "name": "redmine-calendar",
  "version": "1.0.0",
  "description": "Outlook-style weekly calendar for Redmine time tracking",
  "type": "module",
  "license": "MIT",
  "author": "Dominik Hollmann",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominikhollmann/RedmineCalendar.git"
  },
  "bugs": {
    "url": "https://github.com/dominikhollmann/RedmineCalendar/issues"
  },
  "homepage": "https://github.com/dominikhollmann/RedmineCalendar#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "serve": "npx serve . -p 3000",
    "serve:https": "npx serve . -p 3000 --ssl-cert .certs/cert.pem --ssl-key .certs/key.pem",
    "dev": "node scripts/dev-server.mjs",
    "test": "vitest run --config tests/vitest.config.js",
    "test:watch": "vitest --config tests/vitest.config.js",
    "test:coverage": "vitest run --config tests/vitest.config.js --coverage --exclude=tests/unit/sqi-threshold.test.js && vitest run --config tests/vitest.config.js --coverage",
    "test:ui": "playwright test --config tests/playwright.config.js",
    "test:ui:failed": "playwright test --config tests/playwright.config.js --last-failed",
    "test:ui:coverage": "PW_COVERAGE=1 playwright test --config tests/playwright.config.js",
    "test:coverage:all": "npm run test:coverage && npm run test:ui:coverage",
    "test:all": "vitest run --config tests/vitest.config.js && playwright test --config tests/playwright.config.js",
    "lint": "eslint . && stylelint \"css/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint --fix \"css/**/*.css\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "htmlhint": "htmlhint *.html",
    "sqi": "node scripts/sqi.mjs",
    "sqi:json": "node scripts/sqi.mjs --json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "ci:local": "npm run lint && npm run format:check && npm run htmlhint && npm run typecheck && npm run sri:check && npm run knowledge:check && npm run dup:check && npm run oss:drift && npm run oss:licenses && npm run test:coverage && npm run sqi:json",
    "sri:check": "node scripts/sri-check.mjs",
    "knowledge:check": "node scripts/knowledge-check.mjs",
    "dup:report": "jscpd --config .jscpd.json",
    "dup:check": "node scripts/dup-check.mjs",
    "oss:generate": "node scripts/oss-generate.mjs",
    "oss:drift": "node scripts/oss-drift-check.mjs",
    "oss:licenses": "node scripts/oss-check-licenses.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ],
    "*.html": [
      "htmlhint"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "htmlhint": "^1.1.4",
    "husky": "^9.1.7",
    "jscpd": "^5.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "madge": "^8.0.0",
    "monocart-coverage-reports": "^2.12.12",
    "prettier": "^3.8.4",
    "serve": "^14.0.0",
    "spdx-expression-parse": "^4.0.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
